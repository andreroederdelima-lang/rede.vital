# Database
DATABASE_URL=mysql://user:password@127.0.0.1:3306/rede_vital

# Auth
JWT_SECRET=change-me-to-a-random-secret

# Server
PORT=3006
NODE_ENV=production

# Frontend URL (usado em links de recuperacao de senha, etc)
VITE_FRONTEND_URL=http://localhost:3006

# Arquitetura split (Vercel frontend + Railway backend)
# VITE_API_URL vazio = monolito (Railway serve frontend e backend juntos)
# VITE_API_URL=https://rede-vital.up.railway.app = frontend separado (Vercel)
VITE_API_URL=

# CORS: origens permitidas quando frontend estiver separado (vírgula separadas)
# Suporta wildcard para preview deploys: https://rede-vital-*.vercel.app
# Exemplo: CORS_ORIGINS=https://rede-vital.vercel.app,https://rede-vital-*.vercel.app
CORS_ORIGINS=

# Manus OAuth (login admin — só se mantiver Manus como IDP)
OAUTH_SERVER_URL=
VITE_APP_ID=
OWNER_OPEN_ID=

# S3 para upload de imagens (substitui Forge)
# Funciona com AWS S3, Cloudflare R2, MinIO, DigitalOcean Spaces
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=sa-east-1
S3_BUCKET=redevital-credenciados
# S3_ENDPOINT só para S3-compatível não-AWS (ex: https://abc.r2.cloudflarestorage.com)
S3_ENDPOINT=
# S3_PUBLIC_URL_BASE se usar CDN custom (ex: https://cdn.suasaudevital.com.br)
S3_PUBLIC_URL_BASE=

# SMTP para envio de e-mails (substitui Forge)
# Funciona com qualquer provedor SMTP (Resend, SendGrid, AWS SES, Mailgun, Gmail)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=contato@suasaudevital.com.br
# SMTP_SECURE=true apenas para porta 465 (SSL direto); 587 usa STARTTLS automaticamente
SMTP_SECURE=false
