# Rede Vital — variáveis de ambiente obrigatórias

# Segredo usado para assinar tokens JWT (sessões dados-internos, tokens de atualização).
# Gere com: openssl rand -base64 48
JWT_SECRET=

# URL de conexão MySQL (produção). Ex: mysql://user:pass@host:3306/redevital
DATABASE_URL=

# OAuth Manus (login admin via /admin)
OAUTH_SERVER_URL=
VITE_APP_ID=
OWNER_OPEN_ID=

# Forge API (IA e transcrições de voz)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# S3 para upload de imagens (opcional em dev — usa fallback local)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET=

# SMTP para notificações
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Ambiente
NODE_ENV=development
